{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.babyapp.cz"
        }
      ],
      "destination": "https://babyapp.cz/:path*",
      "permanent": true
    },
    {
      "source": "/favicon.ico",
      "destination": "/assets/favicon.ico",
      "permanent": true
    },
    {
      "source": "/favicon.png",
      "destination": "/assets/favicon.png",
      "permanent": true
    },
    {
      "source": "/apple-touch-icon.png",
      "destination": "/assets/favicon.png",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/en/index.html",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/eczema",
      "destination": "/eczema/",
      "permanent": true
    },
    {
      "source": "/signs",
      "destination": "/signs/",
      "permanent": true
    },
    {
      "source": "/main-suspects",
      "destination": "/main-suspects/",
      "permanent": true
    },
    {
      "source": "/en/eczema",
      "destination": "/en/eczema/",
      "permanent": true
    },
    {
      "source": "/en/signs",
      "destination": "/en/signs/",
      "permanent": true
    },
    {
      "source": "/en/main-suspects",
      "destination": "/en/main-suspects/",
      "permanent": true
    },
    {
      "source": "/privacy-policy",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/terms-of-use",
      "destination": "/terms-of-use/",
      "permanent": true
    },
    {
      "source": "/medical-disclaimer",
      "destination": "/medical-disclaimer/",
      "permanent": true
    },
    {
      "source": "/zdroje",
      "destination": "/zdroje/",
      "permanent": true
    },
    {
      "source": "/en/privacy-policy",
      "destination": "/en/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/en/terms-of-use",
      "destination": "/en/terms-of-use/",
      "permanent": true
    },
    {
      "source": "/en/medical-disclaimer",
      "destination": "/en/medical-disclaimer/",
      "permanent": true
    },
    {
      "source": "/en/sources",
      "destination": "/en/sources/",
      "permanent": true
    },
    {
      "source": "/cs/privacy-policy/:path*",
      "destination": "/privacy-policy/",
      "permanent": true
    },
    {
      "source": "/cs/terms-of-use/:path*",
      "destination": "/terms-of-use/",
      "permanent": true
    },
    {
      "source": "/cs/medical-disclaimer/:path*",
      "destination": "/medical-disclaimer/",
      "permanent": true
    },
    {
      "source": "/cs/zdroje/:path*",
      "destination": "/zdroje/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "outputDirectory": "public"
}
